# invoice-ocr-pipeline — environment variable template
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed as documentation.

# Directory where generated PDF invoices are stored
RAW_INVOICES_DIR=raw_invoices

# Number of invoices to generate in Step 1
INVOICE_COUNT=20

# Output paths for the ETL pipeline
EXTRACTED_CSV=data/extracted_invoices.csv
FAILED_CSV=data/failed_invoices.csv
DB_PATH=data/finance_system.db

# Path to the SQL schema file (relative to project root)
SCHEMA_PATH=schema.sql
